# ===========================================
# ClimaticUI - Пример файла окружения
# ===========================================
# Скопируйте этот файл как .env и заполните
# актуальными значениями для вашего проекта
# ===========================================

# -------------------------------------------
# Приложение
# -------------------------------------------
APP_NAME=ClimaticUI
APP_ENV=development
DEBUG=True

# -------------------------------------------
# Streamlit
# -------------------------------------------
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=localhost

# -------------------------------------------
# База данных (если будет использоваться)
# -------------------------------------------
# DATABASE_URL=postgresql://user:password@localhost:5432/climaticdb
# Или для SQLite:
# DATABASE_URL=sqlite:///./climatic.db

# -------------------------------------------
# Секретный ключ для сессий/токенов
# -------------------------------------------
# Сгенерируйте случайную строку для продакшена
# Например: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-change-in-production

# -------------------------------------------
# Email (для будущей функциональности)
# -------------------------------------------
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# -------------------------------------------
# API ключи (если будут использоваться)
# -------------------------------------------
# OPENWEATHER_API_KEY=your-openweathermap-api-key
# WEATHERAPI_KEY=your-weatherapi-key

# -------------------------------------------
# Лимиты и настройки
# -------------------------------------------
MAX_UPLOAD_SIZE=10485760
SESSION_EXPIRE_MINUTES=1440
